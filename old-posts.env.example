# Copy this file to old-posts.env and update the values for your environment.

# Required: absolute path to the WordPress installation that WP-CLI should bootstrap.
export OLD_POSTS_WP_ROOT="/absolute/path/to/wordpress"

# Optional: where generated manifests, logs, CSVs, and reports should be stored.
# The wrapper defaults to <repository>/output when this is omitted.
# export OLD_POSTS_OUTPUT_DIR="/absolute/path/to/delete-old-posts/output"

# Optional WP-CLI bootstrap flags used by run_wp_old_posts.sh.
export OLD_POSTS_SKIP_THEMES="1"
export OLD_POSTS_SKIP_PLUGINS=""

# Suggested workflow defaults for documentation examples.
export OLD_POSTS_POST_TYPE="post"
export OLD_POSTS_STATUSES="publish,draft"
export OLD_POSTS_BEFORE="2017-01-01 00:00:00"
export OLD_POSTS_CHARACTER_LIMIT="300"
export OLD_POSTS_AUDIT_BATCH_SIZE="100"
export OLD_POSTS_POST_BATCH_SIZE="25"
export OLD_POSTS_ATTACHMENT_BATCH_SIZE="10"
export OLD_POSTS_PROGRESS_EVERY="25"
export OLD_POSTS_PROGRESS_SECONDS="30"
export OLD_POSTS_RECHECK_USAGE="1"
